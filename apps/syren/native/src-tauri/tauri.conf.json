{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Syren",
	"version": "0.0.1",
	"identifier": "is.syr.syren.native",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:5176",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Syren",
				"width": 1280,
				"height": 800,
				"minWidth": 360,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {}
}
