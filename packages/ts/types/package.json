{
	"name": "@syren/types",
	"version": "0.0.1",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.ts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "prettier --check . && eslint ."
	},
	"dependencies": {
		"surrealdb": "^1.3.2",
		"ulid": "^3.0.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:",
		"eslint": "catalog:",
		"eslint-config-prettier": "catalog:",
		"prettier": "catalog:",
		"tsup": "^8.5.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "catalog:",
		"vitest": "^4.0.18"
	}
}
