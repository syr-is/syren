{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,

		"lib": ["ES2022", "DOM"],
		"declaration": true,
		"declarationMap": true,

		"outDir": "./dist",
		"rootDir": "./src",

		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts"]
}
