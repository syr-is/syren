# Syren Environment Configuration

# Application
NODE_ENV=development
PORT=5174
# PUBLIC_URL: this instance's external URL.
# Used as platform_origin and callback_url when redirecting to syr.
# For LAN dev, use your machine's IP: http://192.168.1.10:5174
PUBLIC_URL=http://localhost:5174

# SurrealDB Configuration
# Note: syren uses port 8100 to avoid conflict with syr's SurrealDB on 8000
SURREALDB_URL=ws://localhost:8100/rpc
SURREALDB_NAMESPACE=syren
SURREALDB_DATABASE=syren
SURREALDB_USER=root
SURREALDB_PASS=syren-dev-password

# NestJS API
SYREN_API_PORT=5175
SYREN_API_URL=http://localhost:5175

# Default Syr Instance (used as fallback when user doesn't specify)
SYR_INSTANCE_URL=http://localhost:5173

# SeaweedFS / S3 (message attachments)
S3_ENDPOINT=http://localhost:8343
S3_BUCKET=syren
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=syren-access-key
S3_SECRET_ACCESS_KEY=syren-secret-key
# Base URL used to build public attachment URLs. Typically S3_ENDPOINT + /<bucket>.
S3_PUBLIC_URL=http://localhost:8343/syren
# Max bytes per uploaded file (500 MB)
UPLOAD_MAX_BYTES=524288000

# Federated media proxy (IP-leak mitigation)
# 100 MB cap; anything larger triggers the "load directly from remote" UX
PROXY_MAX_BYTES=104857600
PROXY_TIMEOUT_MS=10000
# Allow proxying to RFC1918 / CGNAT addresses. Defaults to TRUE in
# development (NODE_ENV != production) so the same-box syr ↔ syren LAN setup
# works. Set explicitly to `false` to harden even in dev. Loopback and
# link-local are always blocked regardless.
# PROXY_ALLOW_PRIVATE_IPS=false
